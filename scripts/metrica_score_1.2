import pandas as pd
from sqlalchemy import create_engine
from sqlalchemy.pool import NullPool
import numpy as np

print("🚀 Iniciando Métrica 1.2 - Estratégia Distressed...")

# Cria conexão com o banco
engine = create_engine(
    "postgresql+psycopg2://postgres:Fiapdata2025@db.bgkrnjbleagxnhjlggbj.supabase.co:5432/postgres",
    poolclass=NullPool,
)

def calcular_e_salvar_metrica_1_2(conexao_engine):
    print("1. Lendo dados da tabela inf_mensal_fidc_tab_I...")

    query = '''
    SELECT
        "CNPJ_FUNDO_CLASSE",
        "DENOM_SOCIAL",
        "DT_COMPTC",
        "TAB_I2_VL_CARTEIRA",
        "TAB_I2A5_VL_CRED_VENCIDO_PENDENTE",
        "TAB_I2A6_VL_CRED_EMP_RECUP"
    FROM "inf_mensal_fidc_tab_I"
    '''

    df = pd.read_sql_query(query, conexao_engine)

    if df.empty:
        print("Erro: Nenhum dado encontrado na tabela.")
        return

    print("2. Tratando dados...")

    cols_numericas = [
        "TAB_I2_VL_CARTEIRA",
        "TAB_I2A5_VL_CRED_VENCIDO_PENDENTE",
        "TAB_I2A6_VL_CRED_EMP_RECUP"
    ]

    for col in cols_numericas:
        df[col] = pd.to_numeric(df[col], errors="coerce")

    # Evita divisão por zero
    df["TAB_I2_VL_CARTEIRA"] = df["TAB_I2_VL_CARTEIRA"].replace(0, np.nan)

    # Nulos das proxies viram zero
    df["TAB_I2A5_VL_CRED_VENCIDO_PENDENTE"] = df["TAB_I2A5_VL_CRED_VENCIDO_PENDENTE"].fillna(0)
    df["TAB_I2A6_VL_CRED_EMP_RECUP"] = df["TAB_I2A6_VL_CRED_EMP_RECUP"].fillna(0)

    # Remove carteiras muito pequenas para evitar ruído
    df = df[df["TAB_I2_VL_CARTEIRA"] > 1000]

    print("3. Calculando métrica 1.2...")

    # Usa o maior valor entre as proxies para evitar dupla contagem
    df["distressed_total"] = df[[
        "TAB_I2A5_VL_CRED_VENCIDO_PENDENTE",
        "TAB_I2A6_VL_CRED_EMP_RECUP"
    ]].max(axis=1)

    df["metrica_1_2_estrategia_distressed"] = (
        df["distressed_total"] / df["TAB_I2_VL_CARTEIRA"]
    )

    # Limita entre 0 e 1
    df["metrica_1_2_estrategia_distressed"] = df[
        "metrica_1_2_estrategia_distressed"
    ].clip(lower=0, upper=1)

    print("4. Selecionando colunas finais...")

    df_resultado = df[[
        "CNPJ_FUNDO_CLASSE",
        "DENOM_SOCIAL",
        "DT_COMPTC",
        "TAB_I2_VL_CARTEIRA",
        "TAB_I2A5_VL_CRED_VENCIDO_PENDENTE",
        "TAB_I2A6_VL_CRED_EMP_RECUP",
        "distressed_total",
        "metrica_1_2_estrategia_distressed"
    ]].copy()

    print("5. Salvando no Supabase...")

    df_resultado.to_sql(
        "score_1_metrica_2",
        conexao_engine,
        if_exists="replace",
        index=False
    )

    print("✅ Métrica 1.2 salva com sucesso na tabela score_1_metrica_2!")

try:
    calcular_e_salvar_metrica_1_2(engine)
except Exception as e:
    print(f"Erro durante a execução: {e}")
